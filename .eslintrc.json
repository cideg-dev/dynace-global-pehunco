{
    "env": {
        "browser": true,
        "es2021": true
    },
    "parserOptions": {
        "ecmaVersion": 12
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "warn",
        "semi": ["warn", "always"],
        "quotes": ["warn", "single"],
        "no-console": "off"
    }
}
